# HortNet-BD — লোকাল PostgreSQL সেটিংস
PGSSL=off

# তোমার লোকাল PostgreSQL (postgres / 12345678 / port 5432)
MASTER_DB_URL=postgresql://postgres:12345678@localhost:5432/v1_master
TENANT_ASAMBASTI_URL=postgresql://postgres:12345678@localhost:5432/v1_asambasti

# JWT — যেকোনো লম্বা random text (নিচেরটা বদলে দিও)
JWT_SECRET=local_change_this_to_a_long_random_text_now
JWT_EXPIRES_IN=7d

PORT=5000